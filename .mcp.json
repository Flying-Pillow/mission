    "servers": {
        "mission": {
            "type": "stdio",
            "command": "mission-command",
            "args": [],
            "env": {
                "MISSION_MCP_ENDPOINT": "${MISSION_MCP_ENDPOINT}",
                "MISSION_MCP_MISSION_ID": "${MISSION_MCP_MISSION_ID}",
                "MISSION_MCP_TASK_ID": "${MISSION_MCP_TASK_ID}",
                "MISSION_MCP_AGENT_SESSION_ID": "${MISSION_MCP_AGENT_SESSION_ID}",
