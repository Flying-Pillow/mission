{
  "name": "@flying-pillow/mission-airport",
  "version": "0.1.0-alpha.0",
  "description": "Mission airport control-plane state and projection primitives",
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "rm -rf build tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "vp lint src",
    "test": "vp test run --passWithNoTests"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "typescript": "./src/index.ts",
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    },
    "./*": {
      "development": "./src/*",
      "typescript": "./src/*",
      "default": "./build/*"
    }
  },
  "files": [
    "build"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}