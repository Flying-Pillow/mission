{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mission Airport",
  "version": "0.1.0-alpha.0",
  "identifier": "io.flying-pillow.mission.airport",
  "build": {
    "beforeDevCommand": "pnpm run frontend:dev",
    "beforeBuildCommand": "pnpm run frontend:build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/build"
  },
  "app": {
    "windows": [
      {
        "title": "Mission Airport",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "/tmp/mission-airport-icon.png"
    ]
  }
}