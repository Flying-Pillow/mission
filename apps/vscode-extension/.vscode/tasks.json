{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "mission: build",
            "type": "shell",
            "command": "pnpm",
            "args": [
                "run",
                "build"
            ],
            "group": "build",
            "problemMatcher": [
                "$tsc"
            ]
        },
        {
            "label": "mission: watch",
            "type": "shell",
            "command": "pnpm",
            "args": [
                "run",
                "watch"
            ],
            "isBackground": true,
            "group": "build",
            "problemMatcher": [
                "$tsc-watch"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}