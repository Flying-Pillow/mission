{
    "servers": {
        "svelte": {
            "type": "http",
            "url": "https://mcp.svelte.dev/mcp"
        },
        "context7": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp@latest"
            ]
        },
        "stitch": {
            "type": "http",
            "url": "https://stitch.googleapis.com/mcp",
            "headers": {
                "Accept": "application/json",
                "X-Goog-Api-Key": "${env:GOOGLE_STITCH_API_KEY}"
            }
        }
    }
}